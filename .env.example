# Token de acesso gerado na Meta (Usuários do sistema → Gerar token)
ACCESS_TOKEN=seu_token_aqui

# ID da conta de anúncios (formato: act_XXXXXXXXX)
AD_ACCOUNT_ID=act_seu_id_aqui

# ID do negócio (aparece na URL do Business Suite)
BUSINESS_ID=seu_business_id_aqui

# Chave da API do Claude (para análise inteligente dos dados)
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui
